{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Local — iOS Simulator / macOS / Web",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "toolArgs": ["--dart-define=ENV=localSimulatorIOS"]
    },
    {
      "name": "Local — Android Emulator",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "toolArgs": ["--dart-define=ENV=localEmulatorAndroid"]
    },
    {
      "name": "Local — Physical Device (LAN)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "toolArgs": ["--dart-define=ENV=localDevice"]
    },
    {
      "name": "Staging",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "toolArgs": ["--dart-define=ENV=staging"]
    },
    {
      "name": "Prod",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "release",
      "toolArgs": ["--dart-define=ENV=prod"]
    }
  ]
}
